# Tushare 访问令牌，用于获取股票行情数据
TUSHARE_TOKEN=your_tushare_token

# Dify 工作流 API Key，用于生成 AI 分析结果
DIFY_API_KEY=your_dify_api_key

# 飞书机器人 Webhook 地址，用于发送复盘消息
FEISHU_WEBHOOK=your_feishu_webhook

# Dify API 基础地址；默认官方 SaaS 地址，私有化部署时改这里
DIFY_BASE_URL=https://api.dify.ai/v1

# 调试模式：true 时打印报告并输出调试 CSV，不发送飞书通知
DEBUG_MODE=false

# 需要分析的股票列表，多个代码用英文逗号分隔
MY_STOCKS=601880.SH,600157.SH,603010.SH,002372.SZ,600905.SH,600009.SH,600010.SH

# 允许参与分析的交易所，支持 SH,SZ,BJ 或中文别名如 沪深、北交所
ALLOWED_EXCHANGES=SH,SZ,BJ
